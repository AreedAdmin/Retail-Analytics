# Copy to .env for local dev (.env is git-ignored — never commit real keys).
# On HF Spaces set these under Settings -> Variables and secrets (Secrets).

# --- AI narrative layer (Ollama Cloud, primary) ---
OLLAMA_API_KEY=
# Optional overrides (defaults shown):
# OLLAMA_MODEL=gpt-oss:120b-cloud
# OLLAMA_HOST=https://ollama.com          # no /api suffix
# OLLAMA_TIMEOUT=60

# --- Optional LLM fallbacks (only if you set one) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Force a backend explicitly (auto-detects from keys if unset):
# LLM_BACKEND=ollama
